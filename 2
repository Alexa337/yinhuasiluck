<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
</head>

<body style="margin:0; background:#000;">
  <!-- 第 1 张：点击切换 -->
  <img id="clickImg" src="yinhuasiluck/Q1.png" alt=""
    style="width:100vw; height:auto; display:block; cursor:pointer;" />

  <!-- 后面 3 张：固定不变 -->
  <img src="yinhuasiluck/2.png" alt="" style="width:100vw; height:auto; display:block;" />
  <img src="yinhuasiluck/3.png" alt="" style="width:100vw; height:auto; display:block;" />
  <img src="yinhuasiluck/4.png" alt="" style="width:100vw; height:auto; display:block;" />

  <script>
    // 这里放“第一张可轮播”的图片列表（点击会在它们之间切换）
    const clickImages = [
      "yinhuasiluck/Q1.png",
      "yinhuasiluck/yinhuasi1.png",
    ];

    let i = 0;
    const img = document.getElementById("clickImg");

    img.addEventListener("click", () => {
      i = (i + 1) % clickImages.length;
      img.src = clickImages[i] + "?v=" + Date.now(); // 防缓存
    });
  </script>
</body>
</html>
